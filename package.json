{
  "name": "cepheid",
  "version": "0.5.0",
  "description": "CLI tool to manage Claude Code settings, permissions, and skills",
  "main": "dist/index.js",
  "bin": {
    "cepheid": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "templates",
    "registry",
    "skills",
    "README.md",
    "LICENSE",
    "QUICKSTART.md",
    "CONTRIBUTING.md",
    "CLAUDE.md",
    "BEST_PRACTICES.md"
  ],
  "keywords": [
    "claude-code",
    "cli",
    "settings",
    "skills",
    "automation",
    "ai",
    "developer-tools",
    "configuration"
  ],
  "author": "Claude Code Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/g7tianyi/cepheid.git"
  },
  "bugs": {
    "url": "https://github.com/g7tianyi/cepheid/issues"
  },
  "homepage": "https://github.com/g7tianyi/cepheid#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^8.2.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
